<script>
  // Client-side interactive dial logic
  const shutter = ['Bulb','30"','15"','8"','4"','2"','1"','1/2','1/4','1/8','1/15','1/30','1/60','1/125','1/250','1/500','1/1000','1/2000'];
  const aperture = ['ƒ1.4','ƒ2','ƒ2.8','ƒ4','ƒ5.6','ƒ8','ƒ11','ƒ16'];
  const STEP = 25;

  let mode = 'S';
  let shutterIdx = 14;
  let apertureIdx = 3;
  let dialing = false;
  let timerId = null;

  const sBtn = document.getElementById('s-btn');
  const aBtn = document.getElementById('a-btn');
  const bigVal = document.getElementById('big-val');
  const evVal = document.getElementById('ev-val');
  const rulerTrack = document.getElementById('ruler-track');
  const loLabel = document.getElementById('lo-label');
  const hiLabel = document.getElementById('hi-label');
  const dialTrack = document.getElementById('dial-track');

  function curIdx() {
    return mode === 'S' ? shutterIdx : apertureIdx;
  }

  function modeBtnStyle(btn, active) {
    if (active) {
      btn.style.background = 'rgba(201,163,91,.16)';
      btn.style.border = '1.5px solid #C9A35B';
      btn.style.color = '#C9A35B';
    } else {
      btn.style.background = 'rgba(243,238,227,.05)';
      btn.style.border = '1.5px solid transparent';
      btn.style.color = 'rgba(243,238,227,.6)';
    }
  }

  function apply() {
    if (rulerTrack) {
      rulerTrack.style.transform = `translateY(-50%) translateX(${-curIdx() * STEP}px)`;
    }
    if (bigVal) {
      const val = mode === 'S' ? shutter[shutterIdx] : aperture[apertureIdx];
      bigVal.textContent = val;
      const maxed = mode === 'S' && shutterIdx >= 17;
      bigVal.style.color = maxed ? '#D9913C' : '#F3EEE3';
    }
    if (evVal) {
      evVal.style.opacity = dialing ? '1' : '0';
    }
    if (loLabel) {
      loLabel.textContent = mode === 'S' ? 'Bulb' : 'ƒ1.4';
    }
    if (hiLabel) {
      hiLabel.textContent = mode === 'S' ? '1/2000' : 'ƒ16';
    }
  }

  function updateEV() {
    if (evVal) {
      const idx = curIdx();
      const refIdx = mode === 'S' ? 13 : 3;
      const off = refIdx - idx;
      const bias = off * 0.3;
      evVal.textContent = `${bias > 0 ? '+' : ''}${bias.toFixed(1)} EV`;
    }
  }

  sBtn?.addEventListener('click', () => {
    mode = 'S';
    modeBtnStyle(sBtn, true);
    modeBtnStyle(aBtn, false);
    apply();
  });

  aBtn?.addEventListener('click', () => {
    mode = 'A';
    modeBtnStyle(sBtn, false);
    modeBtnStyle(aBtn, true);
    apply();
  });

  // Drag interaction
  dialTrack?.addEventListener('pointerdown', (e) => {
    e.preventDefault();
    dialing = true;
    if (timerId) clearTimeout(timerId);

    const startX = e.clientX;
    const startIdx = curIdx();
    const maxIdx = (mode === 'S' ? shutter.length : aperture.length) - 1;

    apply();
    updateEV();

    function move(ev) {
      const delta = Math.round(-(ev.clientX - startX) / STEP);
      const nextIdx = Math.max(0, Math.min(maxIdx, startIdx + delta));
      if (nextIdx !== curIdx()) {
        if (mode === 'S') {
          shutterIdx = nextIdx;
        } else {
          apertureIdx = nextIdx;
        }
        apply();
        updateEV();
      }
    }

    function up() {
      window.removeEventListener('pointermove', move);
      window.removeEventListener('pointerup', up);
      timerId = setTimeout(() => {
        dialing = false;
        apply();
      }, 1100);
    }

    window.addEventListener('pointermove', move);
    window.addEventListener('pointerup', up);
  });

  dialTrack?.addEventListener('dblclick', (e) => {
    e.preventDefault();
    dialing = true;
    if (timerId) clearTimeout(timerId);

    if (mode === 'S') {
      shutterIdx = 14;
    } else {
      apertureIdx = 3;
    }

    apply();
    updateEV();

    timerId = setTimeout(() => {
      dialing = false;
      apply();
    }, 900);
  });

  // Initial apply
  apply();
</script>
