<script>
  // Client-side interactive dial logic
  const shutter = ['Bulb','30"','15"','8"','4"','2"','1"','1/2','1/4','1/8','1/15','1/30','1/60','1/125','1/250','1/500','1/1000','1/2000'];
  const evComp = ['-3.0','-2.7','-2.3','-2.0','-1.7','-1.3','-1.0','-0.7','-0.3','0','+0.3','+0.7','+1.0','+1.3','+1.7','+2.0','+2.3','+2.7','+3.0'];
  const STEP = 25;

  let mode = 'S';
  let shutterIdx = 14;
  let apertureIdx = 9; // Centered on '0'
  let dialing = false;
  let timerId = null;

  const sBtn = document.getElementById('s-btn');
  const aBtn = document.getElementById('a-btn');
  const bigVal = document.getElementById('big-val');
  const evVal = document.getElementById('ev-val');
  const rulerTrack = document.getElementById('ruler-track');
  const loLabel = document.getElementById('lo-label');
  const hiLabel = document.getElementById('hi-label');
  const dialTrack = document.getElementById('dial-track');

  function curIdx() {
    return mode === 'S' ? shutterIdx : apertureIdx;
  }

  function modeBtnStyle(btn, active) {
    if (active) {
      btn.classList.add('active-mode');
    } else {
      btn.classList.remove('active-mode');
    }
  }

  function apply() {
    if (rulerTrack) {
      rulerTrack.style.transform = `translateY(-50%) translateX(${-curIdx() * STEP}px)`;
    }
    if (bigVal) {
      const val = mode === 'S' ? shutter[shutterIdx] : evComp[apertureIdx];
      bigVal.textContent = mode === 'S' ? val : val + ' EV';
      const maxed = mode === 'S' && shutterIdx >= 17;
      bigVal.style.color = maxed ? '#D9913C' : '#F3EEE3';
    }
    if (evVal) {
      evVal.style.opacity = dialing ? '1' : '0';
    }
    if (loLabel) {
      loLabel.textContent = mode === 'S' ? 'Bulb' : '-3.0';
    }
    if (hiLabel) {
      hiLabel.textContent = mode === 'S' ? '1/2000' : '+3.0';
    }
  }

  function updateEV() {
    if (evVal) {
      if (mode === 'S') {
        const idx = curIdx();
        const refIdx = 13; // 1/125
        const off = idx - refIdx;
        const bias = off * 0.3;
        evVal.textContent = `${bias > 0 ? '+' : ''}${bias.toFixed(1)} EV`;
      } else {
        evVal.textContent = '';
      }
    }
  }

  sBtn?.addEventListener('click', () => {
    mode = 'S';
    modeBtnStyle(sBtn, true);
    modeBtnStyle(aBtn, false);
    apply();
  });

  aBtn?.addEventListener('click', () => {
    mode = 'A';
    modeBtnStyle(sBtn, false);
    modeBtnStyle(aBtn, true);
    apply();
  });

  // Drag interaction with Pointer Capture for seamless touch tracking
  dialTrack?.addEventListener('pointerdown', (e) => {
    e.preventDefault();
    dialTrack.setPointerCapture(e.pointerId);
    dialing = true;
    if (timerId) clearTimeout(timerId);

    const startX = e.clientX;
    const startIdx = curIdx();
    const maxIdx = (mode === 'S' ? shutter.length : evComp.length) - 1;

    apply();
    updateEV();

    function move(ev) {
      if (!dialing) return;
      const delta = Math.round(-(ev.clientX - startX) / STEP);
      const nextIdx = Math.max(0, Math.min(maxIdx, startIdx + delta));
      if (nextIdx !== curIdx()) {
        if (mode === 'S') {
          shutterIdx = nextIdx;
        } else {
          apertureIdx = nextIdx;
        }
        apply();
        updateEV();
        
        // Haptic feedback tick for physical click simulation
        if (navigator.vibrate) {
          navigator.vibrate(8);
        }
      }
    }

    function up(ev) {
      dialTrack.releasePointerCapture(ev.pointerId);
      dialTrack.removeEventListener('pointermove', move);
      dialTrack.removeEventListener('pointerup', up);
      timerId = setTimeout(() => {
        dialing = false;
        apply();
      }, 1100);
    }

    dialTrack.addEventListener('pointermove', move);
    dialTrack.addEventListener('pointerup', up);
  });

  dialTrack?.addEventListener('dblclick', (e) => {
    e.preventDefault();
    dialing = true;
    if (timerId) clearTimeout(timerId);

    if (mode === 'S') {
      shutterIdx = 14;
    } else {
      apertureIdx = 9;
    }

    apply();
    updateEV();

    timerId = setTimeout(() => {
      dialing = false;
      apply();
    }, 900);
  });

  // Initial apply
  apply();
</script>
